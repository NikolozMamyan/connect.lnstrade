{% extends 'layout/app.html.twig' %}
{% block page_title %}Contacts — Mapping des champs{% endblock %}
{% block page_subtitle %}HubSpot Contact → Sage Client › Contact{% endblock %}
{% block content %}
    {% include 'partials/flux_tabs.html.twig' with { flux: 'contacts' } %}
    <div class="flux-info-banner flux-info-banner--note">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div>"Si vide" = champ Sage mis à jour uniquement si vide. <span class="mapping-required">*</span> = obligatoire. <span class="mapping-todo">⚠ À définir</span> = pas encore mappé.</div>
    </div>
    <div class="card">
        <div class="card-header">
            <span class="card-title">Champs Contact</span>
            <span class="flux-direction-badge flux-direction-badge--hs-sage">HubSpot → Sage</span>
        </div>
        <div style="padding:0 4px;">
            <table class="table mapping-table">
                <thead><tr><th>HubSpot</th><th class="mapping-arrow">Sens</th><th>Sage</th><th>Condition</th></tr></thead>
                <tbody>
                    <tr>
                        <td><div class="mapping-source"><span class="mapping-object">Contact</span><span class="mapping-field">First name</span><code class="mapping-api">firstname</code></div></td>
                        <td class="mapping-arrow hs-sage">⇒</td>
                        <td><div class="mapping-source"><span class="mapping-object">Client › Contact</span><span class="mapping-field">Prénom <span class="mapping-required">*</span></span></div></td>
                        <td><span class="mapping-condition">Si vide</span></td>
                    </tr>
                    <tr>
                        <td><div class="mapping-source"><span class="mapping-object">Contact</span><span class="mapping-field">Last name</span><code class="mapping-api">lastname</code></div></td>
                        <td class="mapping-arrow hs-sage">⇒</td>
                        <td><div class="mapping-source"><span class="mapping-object">Client › Contact</span><span class="mapping-field">Nom <span class="mapping-required">*</span></span></div></td>
                        <td><span class="mapping-condition">Si vide</span></td>
                    </tr>
                    <tr>
                        <td><div class="mapping-source"><span class="mapping-object">Contact</span><span class="mapping-field">Email</span><code class="mapping-api">email</code></div></td>
                        <td class="mapping-arrow hs-sage">⇒</td>
                        <td><div class="mapping-source"><span class="mapping-object">Client › Contact</span><span class="mapping-field">E-mail <span class="mapping-required">*</span></span></div></td>
                        <td><span class="mapping-condition">Si vide</span></td>
                    </tr>
                    <tr>
                        <td><div class="mapping-source"><span class="mapping-object">Contact</span><span class="mapping-field">Phone Number</span><code class="mapping-api">phone</code></div></td>
                        <td class="mapping-arrow hs-sage">⇒</td>
                        <td><div class="mapping-source"><span class="mapping-object">Client › Contact</span><span class="mapping-field">Téléphone</span></div></td>
                        <td><span class="mapping-condition">Si vide</span></td>
                    </tr>
                    <tr>
                        <td><div class="mapping-source"><span class="mapping-object">Contact</span><span class="mapping-field">Job Function + Detail</span><code class="mapping-api">job_function</code></div></td>
                        <td class="mapping-arrow hs-sage">⇒</td>
                        <td><div class="mapping-source"><span class="mapping-object">Client › Contact</span><span class="mapping-field">Fonction</span></div></td>
                        <td><span class="mapping-condition">Si vide · concaténation</span></td>
                    </tr>
                    <tr>
                        <td><div class="mapping-source"><span class="mapping-object">Contact</span><span class="mapping-field">Linkedin URL</span><code class="mapping-api">hs_linkedin_url</code></div></td>
                        <td class="mapping-arrow hs-sage">⇒</td>
                        <td><div class="mapping-source"><span class="mapping-object">Client › Contact</span><span class="mapping-field">Linkedin</span></div></td>
                        <td><span class="mapping-condition">Si vide</span></td>
                    </tr>
                    <tr class="mapping-unmapped">
                        <td><span class="mapping-todo">⚠ À définir</span></td>
                        <td class="mapping-arrow">—</td>
                        <td><div class="mapping-source"><span class="mapping-object">Client › Contact</span><span class="mapping-field">Type de contact · Civilité · Service</span></div></td>
                        <td><span style="color:var(--color-warning);font-size:11px;">Non défini</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
