{% extends 'layout/app.html.twig' %}
{% block page_title %}Flux Contacts — Logs{% endblock %}
{% block page_subtitle %}Historique des synchronisations{% endblock %}
{% block content %}
    {% include 'partials/flux_tabs.html.twig' with { flux: 'contacts' } %}
    <div class="card">
        <div class="card-header">
            <span class="card-title">Logs de synchronisation</span>
            <span class="sync-status sync-status--inactive">Non connecté</span>
        </div>
        <div class="card-body" style="text-align:center;padding:var(--space-12) var(--space-8);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--border-color-dark)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto var(--space-4);">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            <p style="font-size:15px;font-weight:600;color:var(--text-secondary);margin-bottom:var(--space-2);">Aucun log disponible</p>
            <p style="font-size:13px;color:var(--text-muted);">Les logs apparaîtront ici une fois le connecteur mis en place.</p>
        </div>
    </div>
{% endblock %}