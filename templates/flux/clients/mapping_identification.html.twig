{% extends 'layout/app.html.twig' %}
{% block page_title %}Clients — Identification{% endblock %}
{% block page_subtitle %}Mapping HubSpot Company ⇄ Sage Client › Identification{% endblock %}
{% block content %}
    {% include 'partials/flux_tabs.html.twig' with { flux: 'clients' } %}
    <div class="card">
        <div class="card-header">
            <span class="card-title">Identification client</span>
            <span class="flux-direction-badge flux-direction-badge--bidir">Bidirectionnel</span>
        </div>
        <div style="padding:0 4px;">
            <table class="table mapping-table">
                <thead><tr><th>HubSpot</th><th class="mapping-arrow">Sens</th><th>Sage</th><th>Condition</th></tr></thead>
                <tbody>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">ID ERP</span><code class="mapping-api">id_erp</code></div></td><td class="mapping-arrow sage-hs">⇐</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Compte tiers <span class="mapping-required">*</span></span></div></td><td><span class="mapping-condition">Si vide</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">Company name</span><code class="mapping-api">name</code></div></td><td class="mapping-arrow hs-sage">⇒</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Intitulé <span class="mapping-required">*</span></span></div></td><td><span class="mapping-condition">Si vide</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Contact (primary)</span><span class="mapping-field">Firstname + Lastname</span></div></td><td class="mapping-arrow hs-sage">⇒</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Interlocuteur</span></div></td><td><span class="mapping-condition">Si vide</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">Street Address</span><code class="mapping-api">address</code></div></td><td class="mapping-arrow hs-sage">⇒</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Adresse <span class="mapping-required">*</span></span></div></td><td><span class="mapping-condition">Si vide</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">Street Address 2</span><code class="mapping-api">address2</code></div></td><td class="mapping-arrow hs-sage">⇒</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Complément</span></div></td><td><span class="mapping-condition">Si vide</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">Postal Code</span><code class="mapping-api">zip</code></div></td><td class="mapping-arrow hs-sage">⇒</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Code postal <span class="mapping-required">*</span></span></div></td><td><span class="mapping-condition">Si vide</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">City</span><code class="mapping-api">city</code></div></td><td class="mapping-arrow hs-sage">⇒</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Ville <span class="mapping-required">*</span></span></div></td><td><span class="mapping-condition">Si vide</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">Country</span><code class="mapping-api">company_country_en</code></div></td><td class="mapping-arrow hs-sage">⇒</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Pays <span class="mapping-required">*</span></span></div></td><td><span class="mapping-condition">Si vide · traduction FR ?</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">SIRET</span><code class="mapping-api">siret</code></div></td><td class="mapping-arrow bidir">⇄</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Siret</span></div></td><td><span class="mapping-condition">Si vide · bidirectionnel</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">NAF code</span><code class="mapping-api">naf_code</code></div></td><td class="mapping-arrow bidir">⇄</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Code NAF</span></div></td><td><span class="mapping-condition">Si vide · bidirectionnel</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">TVA Intracommunautaire</span><code class="mapping-api">tva_intracommunautaire</code></div></td><td class="mapping-arrow bidir">⇄</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Identifiant TVA <span class="mapping-required">*</span></span></div></td><td><span class="mapping-condition">Si vide · bidirectionnel</span></td></tr>
                    <tr><td><div class="mapping-source"><span class="mapping-object">Company</span><span class="mapping-field">Record ID</span><code class="mapping-api">hs_object_id</code></div></td><td class="mapping-arrow hs-sage">⇒</td><td><div class="mapping-source"><span class="mapping-object">Client › Champs libres</span><span class="mapping-field">HUBSPOT_ID <span class="mapping-required">*</span></span></div></td><td><span class="mapping-condition">Si vide</span></td></tr>
                    <tr class="mapping-unmapped"><td><span class="mapping-todo">⚠ À définir</span></td><td class="mapping-arrow">—</td><td><div class="mapping-source"><span class="mapping-object">Client › Identification</span><span class="mapping-field">Abrégé · Compte collectif · Qualité</span></div></td><td><span style="color:var(--color-warning);font-size:11px;">Non défini</span></td></tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
