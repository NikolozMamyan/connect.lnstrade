{% extends 'layout/app.html.twig' %}
{% block page_title %}Clients — Solvabilité & Encours{% endblock %}
{% block page_subtitle %}HubSpot Company ⇄ Sage Client › Solvabilité{% endblock %}
{% block content %}
    {% include 'partials/flux_tabs.html.twig' with { flux: 'clients' } %}
    <div class="flux-info-banner flux-info-banner--note">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div>Mapping en cours de définition. Certains champs sont encore à spécifier (<span class="mapping-todo">⚠ À définir</span>).</div>
    </div>
    <div class="card">
        <div class="card-header">
            <span class="card-title">Clients — Solvabilité & Encours</span>
            <span class="sync-status sync-status--pending">En cours de définition</span>
        </div>
        <div class="card-body" style="text-align:center;padding:var(--space-12) var(--space-8);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--border-color-dark)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto var(--space-4);"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            <p style="font-size:15px;font-weight:600;color:var(--text-secondary);margin-bottom:var(--space-2);">Mapping à définir</p>
            <p style="font-size:13px;color:var(--text-muted);">Ce mapping sera renseigné une fois les champs Sage clarifiés.</p>
        </div>
    </div>
{% endblock %}