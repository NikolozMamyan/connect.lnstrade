{% extends 'layout/app.html.twig' %}
{% block page_title %}Flux Clients / Sociétés{% endblock %}
{% block page_subtitle %}Synchronisation bidirectionnelle HubSpot Company ⇄ Sage Client{% endblock %}
{% block page_actions %}
    <button class="btn btn-secondary btn-sm">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
        Forcer la synchro
    </button>
{% endblock %}
{% block content %}
    {% include 'partials/flux_tabs.html.twig' with { flux: 'clients' } %}
    <div class="flux-header">
        <span class="flux-direction-badge flux-direction-badge--bidir">HubSpot Company ⇄ Sage Client</span>
    </div>
    <div class="flux-info-banner flux-info-banner--warning">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <div>
            <strong>Création :</strong> Les clients créés dans Sage sont créés comme Sociétés dans HubSpot. Les entreprises créées dans HubSpot ne sont <strong>pas</strong> créées dans Sage.<br>
            <strong>Modification :</strong> SIRET, Code NAF et TVA intracommunautaire sont bidirectionnels. Les autres champs doivent être modifiés depuis HubSpot (priorité HubSpot).
        </div>
    </div>
    <div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:var(--space-6);">
        <div class="stat-card"><div class="stat-header"><span class="stat-label">Clients Sage</span><div class="stat-icon accent"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div></div><div class="stat-value">—</div><div class="stat-delta" style="color:var(--text-muted)">À implémenter</div></div>
        <div class="stat-card"><div class="stat-header"><span class="stat-label">Sociétés HubSpot</span><div class="stat-icon blue"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div></div><div class="stat-value">—</div><div class="stat-delta" style="color:var(--text-muted)">À implémenter</div></div>
        <div class="stat-card"><div class="stat-header"><span class="stat-label">Non synchronisés</span><div class="stat-icon orange"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg></div></div><div class="stat-value">—</div><div class="stat-delta" style="color:var(--text-muted)">À implémenter</div></div>
        <div class="stat-card"><div class="stat-header"><span class="stat-label">Erreurs</span><div class="stat-icon red"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E8394D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div></div><div class="stat-value">—</div><div class="stat-delta" style="color:var(--text-muted)">À implémenter</div></div>
    </div>
    <div class="card">
        <div class="card-header"><span class="card-title">Règles de synchronisation</span></div>
        <div style="padding:0 4px;">
            <table class="table">
                <thead><tr><th>Déclencheur</th><th>Sens</th><th>Action</th><th>Statut</th></tr></thead>
                <tbody>
                    <tr><td>Client créé dans Sage</td><td><span class="mapping-arrow sage-hs" style="font-family:var(--font-mono)">⇒</span> HubSpot</td><td>Création d'une Société dans HubSpot avec HUBSPOT_ID renvoyé</td><td><span class="sync-status sync-status--pending">À implémenter</span></td></tr>
                    <tr><td>Company créée dans HubSpot</td><td style="color:var(--text-muted);font-style:italic">Non prévu</td><td>Pas de création dans Sage</td><td><span class="sync-status sync-status--inactive">Hors scope</span></td></tr>
                    <tr><td>SIRET / Code NAF / TVA modifié</td><td><span style="font-family:var(--font-mono);color:var(--color-brand-accent)">⇄</span> Bidir.</td><td>Mise à jour des deux côtés</td><td><span class="sync-status sync-status--pending">À implémenter</span></td></tr>
                    <tr><td>Autres champs modifiés (HubSpot)</td><td><span class="mapping-arrow hs-sage" style="font-family:var(--font-mono)">⇒</span> Sage</td><td>HubSpot a la priorité — écrase Sage</td><td><span class="sync-status sync-status--pending">À implémenter</span></td></tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
