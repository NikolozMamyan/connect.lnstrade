{# ════════════════════════════════════════
   PARTIAL · Flux Tabs
   Usage : {% include 'partials/flux_tabs.html.twig' with { flux: 'contacts' } %}
   flux : 'contacts' | 'clients' | 'produits' | 'commandes'
   ════════════════════════════════════════ #}

{% set current_route = app.request.attributes.get('_route') %}

{% if flux == 'contacts' %}
    <nav class="flux-tabs">
        <a href="{{ path('flux_contacts_index') }}"
           class="flux-tab {{ current_route == 'flux_contacts_index' ? 'active' : '' }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Vue d'ensemble
        </a>
        <a href="{{ path('flux_contacts_mapping') }}"
           class="flux-tab {{ current_route == 'flux_contacts_mapping' ? 'active' : '' }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            Mapping des champs
        </a>
        <a href="{{ path('flux_contacts_logs') }}"
           class="flux-tab {{ current_route == 'flux_contacts_logs' ? 'active' : '' }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Logs
        </a>
    </nav>

{% elseif flux == 'clients' %}
