{# ════════════════════════════════════════
   PARTIAL · Sidebar — LSTRADE Extranet
   Mise à jour avec les flux HubSpot x Sage
   ════════════════════════════════════════ #}

{% set current_route = app.request.attributes.get('_route') %}

<aside class="sidebar">

    {# ── Logo / Brand ── #}
    <div class="sidebar-logo">
        <div class="logo-mark">LS</div>
        <div class="logo-text">
            <span class="logo-name">LSTRADE</span>
            <span class="logo-sub">Extranet</span>
        </div>
    </div>

    <nav class="sidebar-nav">

        {# ─ Section : Principal ─ #}
        <span class="nav-section-label">Principal</span>

        <a href="{{ path('app_dashboard') }}"
           class="nav-item {{ current_route == 'dashboard' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
            </svg>
            Tableau de bord
        </a>

        {# ─ Section : Flux de synchronisation ─ #}
        <span class="nav-section-label">Flux HubSpot × Sage</span>

        {# Flux Contacts #}
        <a href="{{ path('flux_contacts_index') }}"
           class="nav-item {{ current_route starts with 'flux_contacts' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            Contacts
            <span class="nav-flux-badge nav-flux-badge--hs-sage" title="HubSpot → Sage">HS⇒S</span>
        </a>

        {# Flux Clients / Sociétés #}
        <a href="{{ path('flux_clients_index') }}"
           class="nav-item {{ current_route starts with 'flux_clients' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
            Clients / Sociétés
            <span class="nav-flux-badge nav-flux-badge--bidir" title="Bidirectionnel">⇄</span>
        </a>

        {# Flux Produits / Articles #}
        <a href="{{ path('flux_produits_index') }}"
           class="nav-item {{ current_route starts with 'flux_produits' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            Produits / Articles
            <span class="nav-flux-badge nav-flux-badge--sage-hs" title="Sage → HubSpot">S⇒HS</span>
        </a>

        {# Flux Commandes / Deals #}
        <a href="{{ path('flux_commandes_index') }}"
           class="nav-item {{ current_route starts with 'flux_commandes' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                <line x1="3" y1="6" x2="21" y2="6"/>
                <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            Commandes / Deals
            <span class="nav-flux-badge nav-flux-badge--sage-hs" title="Sage → HubSpot">S⇒HS</span>
        </a>

        {# ─ Section : Supervision ─ #}
        <span class="nav-section-label">Supervision</span>

        <a href=""
           class="nav-item {{ current_route starts with 'logs' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            Logs de synchronisation
            {% if nb_erreurs is defined and nb_erreurs > 0 %}
                <span class="nav-badge">{{ nb_erreurs }}</span>
            {% endif %}
        </a>

        <a href=""
           class="nav-item {{ current_route == 'statistiques' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
            Statistiques
        </a>

        {# ─ Section : Système ─ #}
        <span class="nav-section-label">Système</span>

        <a href=""
           class="nav-item {{ current_route starts with 'parametres' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
            </svg>
            Paramètres
        </a>

    </nav>

    {# ── Footer utilisateur ── #}
    <div class="sidebar-footer">
        <div class="user-card">
            <div class="user-avatar">
                {{ app.user ? (app.user.prenom|first ~ app.user.nom|first)|upper : 'U' }}
            </div>
            <div class="user-info">
                <div class="user-name">
                    {{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Utilisateur' }}
                </div>
                <div class="user-role">
                    {{ app.user ? app.user.roles|first|replace({'ROLE_': '', '_': ' '})|title : '' }}
                </div>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>
            </svg>
        </div>
    </div>

</aside>
