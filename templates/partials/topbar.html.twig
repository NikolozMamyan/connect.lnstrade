{# ════════════════════════════════════════
   PARTIAL · Topbar
   Inclus automatiquement par layout/app.html.twig
   Le breadcrumb est délégué au partial dédié.
   ════════════════════════════════════════ #}

<header class="topbar">

    {# ── Breadcrumb ── #}
    {% include 'partials/breadcrumb.html.twig' %}

    {# ── Spacer ── #}
    <div class="topbar-spacer"></div>

    {# ── Barre de recherche ── #}
    <div class="topbar-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#8B90AB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text"
               id="topbar-search-input"
               placeholder="Rechercher…"
               autocomplete="off"/>
        <kbd class="search-kbd">⌘K</kbd>
    </div>

    {# ── Actions icônes ── #}
    <div class="topbar-actions">

        {# Notifications #}
        <button class="icon-btn"
                title="Notifications"
                id="btn-notifications"
                aria-label="Voir les notifications">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            {% if nb_notifications is defined and nb_notifications > 0 %}
                <span class="notif-dot"></span>
            {% endif %}
        </button>

        {# Aide #}
        <a href="" class="icon-btn" title="Aide" aria-label="Aide">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </a>

        {# Avatar / Profil #}
        <a href=""
           class="topbar-avatar"
           title="Mon profil"
           aria-label="Accéder à mon profil">
            {{ app.user ? (app.user.prenom|first ~ app.user.nom|first)|upper : 'U' }}
        </a>

    </div>

</header>
